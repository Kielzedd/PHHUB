-- Tab Frames Container
local Tabs = {}
local TabButtons = {}

local function createTab(name, index)
    local TabFrame = Instance.new("Frame")
    TabFrame.Size = UDim2.new(1, 0, 1, 0)
    TabFrame.BackgroundTransparency = 1
    TabFrame.Visible = (index == 1)
    TabFrame.Parent = ContentArea
    
    -- Auto grid sorting inside the tab
    local UIGrid = Instance.new("UIGridLayout")
    UIGrid.CellSize = UDim2.new(0.5, -10, 0, 48)
    UIGrid.CellPadding = UDim2.new(0, 10, 0, 10)
    UIGrid.Parent = TabFrame
    
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(1, 0, 0, 40)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name
    TabBtn.TextColor3 = (index == 1) and Color3.fromRGB(252, 209, 22) or Color3.fromRGB(138, 143, 157)
    TabBtn.TextSize = 13
    TabBtn.Font = Enum.Font.SourceSansBold
    TabBtn.Parent = Sidebar
    
    TabBtn.MouseButton1Click:Connect(function()
        sounds.tab()
        for i, tFrame in ipairs(Tabs) do
            tFrame.Visible = (i == index)
            TabButtons[i].TextColor3 = (i == index) and Color3.fromRGB(252, 209, 22) or Color3.fromRGB(138, 143, 157)
        end
    end)
    
    table.insert(Tabs, TabFrame)
    table.insert(TabButtons, TabBtn)
    return TabFrame
end

