SavedListLayout.Padding = UDim.new(0, 5)

local savedScripts = {}
local function renderScripts()
    for _, child in ipairs(SavedListFrame:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end
    for idx, data in ipairs(savedScripts) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 30)
        row.BackgroundColor3 = Color3.fromRGB(20, 22, 27)
        row.Parent = SavedListFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

        local sName = Instance.new("TextLabel")
        sName.Size = UDim2.new(0.4, 0, 1, 0)
        sName.Position = UDim2.new(0, 8, 0, 0)
        sName.BackgroundTransparency = 1
        sName.Text = data.name
        sName.TextColor3 = currentTheme.Primary
        sName.Font = Enum.Font.SourceSansBold
        sName.TextSize = 10
        sName.TextXAlignment = Enum.TextXAlignment.Left
        sName.Parent = row

        local exeBtn = Instance.new("TextButton")
        exeBtn.Size = UDim2.new(0, 35, 0, 20)
        exeBtn.Position = UDim2.new(1, -115, 0.5, -10)
        exeBtn.BackgroundTransparency = 1
        exeBtn.Text = "▶ Exe"
        exeBtn.TextColor3 = Color3.fromRGB(0, 230, 118)
        exeBtn.Font = Enum.Font.SourceSansBold
        exeBtn.TextSize = 10
        exeBtn.Parent = row
        exeBtn.MouseButton1Click:Connect(function()
            playSound("rbxassetid://6895079853")
            showNotification("▶ Executing Script!")
            pcall(function() loadstring(data.script)() end)
        end)

        local copyBtn = Instance.new("TextButton")
        copyBtn.Size = UDim2.new(0, 35, 0, 20)
        copyBtn.Position = UDim2.new(1, -75, 0.5, -10)
        copyBtn.BackgroundTransparency = 1
        copyBtn.Text = "📋 Copy"
        copyBtn.TextColor3 = Color3.fromRGB(0, 229, 255)
        copyBtn.Font = Enum.Font.SourceSansBold
        copyBtn.TextSize = 10
        copyBtn.Parent = row
        copyBtn.MouseButton1Click:Connect(function()
            playSound("rbxassetid://6895079853")
            if setclipboard then setclipboard(data.script) end
            showNotification("✅ Script Copied!")
        end)

        local delBtn = Instance.new("TextButton")
        delBtn.Size = UDim2.new(0, 30, 0, 20)
        delBtn.Position = UDim2.new(1, -35, 0.5, -10)
        delBtn.BackgroundTransparency = 1
        delBtn.Text = "🗑️ Del"
        delBtn.TextColor3 = Color3.fromRGB(255, 0, 85)
        delBtn.Font = Enum.Font.SourceSansBold
        delBtn.TextSize = 10
        delBtn.Parent = row
        delBtn.MouseButton1Click:Connect(function()
            playSound("rbxassetid://6895079853")
            table.remove(savedScripts, idx)
            renderScripts()
            showNotification("🗑️ Script Deleted!")
        end)
    end
end

SaveBtn.MouseButton1Click:Connect(function()
    playSound("rbxassetid://6895079853")
    if NameInput.Text ~= "" and CodeInput.Text ~= "" then
        table.insert(savedScripts, { name = NameInput.Text, script = CodeInput.Text })
        NameInput.Text = ""
        CodeInput.Text = ""
        renderScripts()
        showNotification("💾 Script Saved!")
    end
end)

