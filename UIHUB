    Label.BackgroundTransparency = 1
    Label.Text = lang.en[textKey]
    Label.TextColor3 = Color3.fromRGB(226, 226, 233)
    Label.TextSize = 11
    Label.Font = Enum.Font.GothamBold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container
    
    registeredElements[Label] = textKey

    local Switch = Instance.new("TextButton")
    Switch.Size = UDim2.new(0, 42, 0, 22)
    Switch.Position = UDim2.new(1, -54, 0.5, -11)
    Switch.BackgroundColor3 = Color3.fromRGB(62, 68, 81)
    Switch.Text = ""
    Switch.Parent = Container
    
    local SwitchCorner = Instance.new("UICorner")
    SwitchCorner.CornerRadius = UDim.new(1, 0)
    SwitchCorner.Parent = Switch

    local Knob = Instance.new("Frame")
    Knob.Size = UDim2.new(0, 16, 0, 16)
    Knob.Position = UDim2.new(0, 3, 0.5, -8)
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Knob.BorderSizePixel = 0
    Knob.Parent = Switch
    
    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(1, 0)
    KnobCorner.Parent = Knob

    local active = false
    Switch.MouseButton1Click:Connect(function()
        active = not active
        if active then
            sounds.toggleOn()
            TweenService:Create(Switch, TweenInfo.new(0.25), {BackgroundColor3 = Color3.fromRGB(0, 230, 118)}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.25), {Position = UDim2.new(1, -19, 0.5, -8)}):Play()
        else
            sounds.toggleOff()
            TweenService:Create(Switch, TweenInfo.new(0.25), {BackgroundColor3 = Color3.fromRGB(62, 68, 81)}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.25), {Position = UDim2.new(0, 3, 0.5, -8)}):Play()
        end
        if callback then callback(active) end
    end)
end

