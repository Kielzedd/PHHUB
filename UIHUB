    local pane = Create("ScrollingFrame", {Parent=ContentArea, Size=UDim2.new(1, -20, 1, -20), Position=UDim2.new(0, 10, 0, 10), BackgroundTransparency=1, Visible=isFirst, ScrollBarThickness=2})
