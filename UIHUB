    for idx, sData in pairs(scripts) do
        local frame = Create("Frame", {Parent=ScriptListArea, Size=UDim2.new(1,0,0,40), BackgroundColor3=Color3.fromRGB(20,22,27), UICorner=Create("UICorner", {CornerRadius=UDim.new(0,5)})})
