-- ================= PREMIUM SYSTEM TAB GENERATOR =================
local Tabs = {}
local TabButtons = {}

local function createTab(nameKey, index)
    -- Ginamit natin ay ScrollingFrame para hinding-hindi na mag-overlap ang UI kahit marami ang buttons!
    local TabFrame = Instance.new("ScrollingFrame")
    TabFrame.Size = UDim2.new(1, 0, 1, 0)
    TabFrame.BackgroundTransparency = 1
    TabFrame.BorderSizePixel = 0
    TabFrame.ScrollBarThickness = 3
    TabFrame.ScrollBarImageColor3 = Color3.fromRGB(252, 209, 22)
    TabFrame.Visible = (index == 1)
    TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabFrame.Parent = ContentArea
    
    -- Pixel-Perfect Grid Layout (2 columns, walang siksikan)
    local UIGrid = Instance.new("UIGridLayout")
    UIGrid.CellSize = UDim2.new(0.5, -5, 0, 48)
    UIGrid.CellPadding = UDim2.new(0, 10, 0, 10)
    UIGrid.SortOrder = Enum.SortOrder.LayoutOrder
    UIGrid.Parent = TabFrame
    
    local UIPadding = Instance.new("UIPadding")
    UIPadding.PaddingLeft = UDim.new(0, 10)
    UIPadding.PaddingRight = UDim.new(0, 10)
    UIPadding.PaddingTop = UDim.new(0, 10)
    UIPadding.PaddingBottom = UDim.new(0, 10)
    UIPadding.Parent = TabFrame

    -- Navigation Sidebar Button
    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(1, 0, 0, 40)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = lang.en[nameKey]
    TabBtn.TextColor3 = (index == 1) and Color3.fromRGB(252, 209, 22) or Color3.fromRGB(138, 143, 157)
    TabBtn.TextSize = 13
    TabBtn.Font = Enum.Font.SourceSansBold
    TabBtn.Parent = Sidebar
    
    registeredElements[TabBtn] = nameKey
    
    TabBtn.MouseButton1Click:Connect(function()
        sounds.tab()
        for i, tFrame in ipairs(Tabs) do
            tFrame.Visible = (i == index)
            TabButtons[i].TextColor3 = (i == index) and Color3.fromRGB(252, 209, 22) or Color3.fromRGB(138, 143, 157)
        end
    end)
    
    table.insert(Tabs, TabFrame)
    table.insert(TabButtons, TabBtn)
    return TabFrame
end

