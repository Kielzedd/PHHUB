    sounds.loading()
    
    for i = 1, #logs do
        StatusText.Text = logs[i]
        local tween = TweenService:Create(ProgressBar, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(i / #logs, 0, 1, 0)
        })
        tween:Play()
        tween.Completed:Wait()
        task.wait(0.25)
    end
    
    sounds.success()
    
