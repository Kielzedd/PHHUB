local function createTextBox(parent, placeholderKey, callback)
    local TextBox = Instance.new("TextBox")
    TextBox.BackgroundColor3 = Color3.fromRGB(25, 27, 34)
    TextBox.PlaceholderText = lang.en[placeholderKey]
    TextBox.PlaceholderColor3 = Color3.fromRGB(138, 143, 157)
    TextBox.Text = ""
    TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextBox.TextSize = 11
    TextBox.Font = Enum.Font.SourceSansBold
    TextBox.Parent = parent

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 10)
    Corner.Parent = TextBox
    
    local Border = Instance.new("UIStroke")
    Border.Thickness = 1
    Border.Color = Color3.fromRGB(255, 255, 255)
    Border.Transparency = 0.95
    Border.Parent = TextBox
    
    registeredElements[TextBox] = placeholderKey
    
    TextBox.Focused:Connect(function()
        TweenService:Create(Border, TweenInfo.new(0.2), {Color = Color3.fromRGB(252, 209, 22), Transparency = 0}):Play()
    end)
    TextBox.FocusLost:Connect(function()
        TweenService:Create(Border, TweenInfo.new(0.2), {Color = Color3.fromRGB(255, 255, 255), Transparency = 0.95}):Play()
        sounds.tab()
        if callback then callback(TextBox.Text) end
    end)
end

