local QuoteTxt = Create("TextLabel", {Parent=LoadingPanel, Size=UDim2.new(0.8,0,0,40), Position=UDim2.new(0.1,0,0.7,0), BackgroundTransparency=1, Text="\"Motivation: Do your best, and God will do the rest.\"", TextColor3=Themes.cyberpunk.text, Font=Enum.Font.GothamBold, TextSize=13, TextWrapped=true})

local Motivations = {
    "Motivation: Do your best, and God will do the rest.",
    "Motivation: Be proud of yourself and who you are.",
    "Motivation: Small steps every day lead to big results.",
    "Motivation: Believe you can and you're halfway there.",
    "Motivation: Push yourself, because no one else is going to do it for you."
}
local Logs = {
    "Authenticating with backend servers...",
    "Loading Game List configurations...",
    "Injecting UI Overlays & Themes...",
    "Finalizing dynamic structures...",
    "Bypass Complete. Welcome back!"
}

task.spawn(function()
    for i = 1, #Logs do
        StatusTxt.Text = Logs[i]
        TweenService:Create(Bar, TweenInfo.new(0.8), {Size=UDim2.new(i/#Logs,0,1,0)}):Play()
        if i % 2 == 0 then QuoteTxt.Text = "\"" .. Motivations[math.random(1, #Motivations)] .. "\"" end
        task.wait(0.8)
    end
    task.wait(0.5)
    LoadingPanel.Visible = false
    MainPanel.Visible = true
    UpdateLanguage()
    Notify("Successfully Injected!")
end)

ChangeTheme(CurrentTheme)
