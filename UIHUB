-- 5. Speed Input
createInput(tabSet, "speed", function(val)
    local num = tonumber(val)
    if num and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = num
        showNotification("⚡ Speed Set to: " .. num)
    end
end)

-- 6. Music / Song ID Input (FIXED: Bound to SoundService)
createInput(tabSet, "robloxId", function(val)
    local id = string.match(val, "%d+") -- extract numbers only
    if id then
        CustomMusic.SoundId = "rbxassetid://" .. id
        CustomMusic.TimePosition = 0 -- Reset song to start
        CustomMusic:Play()
        showNotification("🎵 Playing Music ID: " .. id)
    else
        showNotification("❌ Invalid Music ID")
    end
end)

-- 7. Adjustable Volume Slider
createSlider(tabSet, "🔊 Global Volume", function(val)
    MasterVolume = val
    CustomMusic.Volume = val
end)

-- Translate Button
createButton(tabSet, "trans", function()
    langIndex = (langIndex % #langCodes) + 1
    local code = langCodes[langIndex]
    local dict = langs[code]
    for _, item in ipairs(registeredElements) do
        if item.Type == "Text" or item.Type == "TabBtn" then
            item.Node.Text = dict[item.Key] or item.Key
        elseif item.Type == "Placeholder" then
            item.Node.PlaceholderText = dict[item.Key] or item.Key
        end
    end
    showNotification("Language: " .. code:upper())
end)


