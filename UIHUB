local function UpdateLanguage()
    local dict = Langs[LangCodes[LangIndex]]
    for _, item in pairs(Translatable) do
        if item.type == "text" then item.node.Text = dict[item.key] or item.key
        elseif item.type == "placeholder" then item.node.PlaceholderText = dict[item.key] or item.key end
    end
end

local function ChangeTheme(themeId)
    local t = Themes[themeId]
    CurrentTheme = themeId
    MainPanel.BackgroundColor3 = t.bg
    MainStroke.Color = t.border
    MiniStroke.Color = t.border
    Minibox.TextColor3 = t.text
    Title.TextColor3 = t.text
    
    for _, txt in pairs(ThemeElements.Text) do
        if txt.Parent and txt.Parent.BackgroundTransparency == 0 then txt.TextColor3 = t.text end
    end
    for _, item in pairs(ThemeElements.Items) do
        item.BackgroundColor3 = t.item
    end
end

