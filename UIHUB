    tabPane.Size = UDim2.new(1, -10, 1, -10)
    tabPane.Position = UDim2.new(0, 5, 0, 5)
    tabPane.BackgroundTransparency = 1
    tabPane.Visible = isFirst
    tabPane.ScrollBarThickness = 2
    tabPane.Parent = Content

    local grid = Instance.new("UIGridLayout", tabPane)
    grid.CellSize = UDim2.new(0, 165, 0, 38)
    grid.CellPadding = UDim2.new(0, 8, 0, 8)

    local elementObj = { Node = tabBtn, Key = key, Type = "TabBtn", IsActive = isFirst }
    table.insert(registeredElements, elementObj)

    if isFirst then activeTab = tabPane end

    tabBtn.MouseButton1Click:Connect(function()
        playSound("rbxassetid://6895079853")
        for _, t in pairs(tabs) do
            t.Pane.Visible = false
            t.Btn.TextColor3 = Color3.fromRGB(138, 143, 157)
            t.Btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            t.Btn.BackgroundTransparency = 1
        end
        for _, el in ipairs(registeredElements) do
            if el.Type == "TabBtn" then el.IsActive = false end
        end

        elementObj.IsActive = true
        tabPane.Visible = true
        tabBtn.TextColor3 = currentTheme.Primary
        tabBtn.BackgroundColor3 = Color3.fromRGB(20, 22, 27)
        tabBtn.BackgroundTransparency = 0
    end)

    tabs[key] = { Btn = tabBtn, Pane = tabPane }
    return tabPane
end

