local function GetSavedScripts()
    if isfile and isfile("PHHUB_Scripts.json") then
        local succ, res = pcall(function() return HttpService:JSONDecode(readfile("PHHUB_Scripts.json")) end)
        if succ then return res end
    end
    return {}
end

local function SaveSavedScripts(data)
    if writefile then writefile("PHHUB_Scripts.json", HttpService:JSONEncode(data)) end
end

